generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  IN_PRODUCTION
  COMPLETED
  CLOSED
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
  CARD
  CHEQUE
  OTHER
}

enum StockTransactionType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT
  RETURN
  INITIAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotations         Quotation[]
  payments           Payment[]
  projectNotes       ProjectNote[]
  stockTransactions  StockTransaction[]
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  hsnCode       String?
  order         Int           @default(0)
  items         Item[]
  subCategories SubCategory[]
}

model SubCategory {
  id         String   @id @default(cuid())
  name       String
  hsnCode    String?
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  items      Item[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Item {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  hsnCode     String?
  brand       String?
  unit        String  @default("Pc(s)")

  gstRate  Float  @default(18)
  taxType  String @default("exclusive")

  unitPrice            Float
  purchasePrice        Float?
  purchasePriceInclTax Float?
  profitMargin         Float?

  manageStock   Boolean @default(false)
  alertQuantity Int     @default(0)
  stock         Int?

  supplier String?
  imageUrl String?
  active   Boolean @default(true)

  category      Category     @relation(fields: [categoryId], references: [id])
  categoryId    String
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  subCategoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templateItems     TemplateItem[]
  quotationItems    QuotationItem[]
  stockTransactions StockTransaction[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([name])
  @@index([brand])
}

model Template {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      TemplateItem[]
  quotations Quotation[]
}

model TemplateItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  item       Item     @relation(fields: [itemId], references: [id])
  itemId     String

  @@unique([templateId, itemId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotations Quotation[]

  @@index([name])
  @@index([mobile])
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  title           String?
  status          QuotationStatus @default(DRAFT)
  subtotal        Float           @default(0)
  gstPercent      Float           @default(18)
  gstAmount       Float           @default(0)
  discount        Float           @default(0)
  grandTotal      Float           @default(0)
  notes           String?
  terms           String?
  validUntil      DateTime?
  completionDate  DateTime?
  billDate        DateTime  @default(now())
  roundOff        Float     @default(0)
  includeGst      Boolean   @default(true)

  customer    Customer  @relation(fields: [customerId], references: [id])
  customerId  String
  template    Template? @relation(fields: [templateId], references: [id])
  templateId  String?
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items             QuotationItem[]
  payments          Payment[]
  projectNotes      ProjectNote[]
  stockTransactions StockTransaction[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model QuotationItem {
  id          String  @id @default(cuid())
  name        String
  description String?
  hsnCode     String?
  quantity    Int     @default(1)
  unit        String  @default("No")
  unitPrice   Float
  discount    Float   @default(0)
  gstRate     Float   @default(18)
  total       Float
  notes       String?
  sortOrder   Int     @default(0)

  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  item        Item?     @relation(fields: [itemId], references: [id])
  itemId      String?

  @@index([quotationId])
}

model Payment {
  id            String      @id @default(cuid())
  amount        Float
  date          DateTime
  mode          PaymentMode
  transactionId String?
  notes         String?

  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId  String
  recordedBy   User      @relation(fields: [recordedById], references: [id])
  recordedById String

  createdAt DateTime @default(now())

  @@index([quotationId])
}

model ProjectNote {
  id       String  @id @default(cuid())
  content  String
  imageUrl String?

  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())

  @@index([quotationId])
}

model StockTransaction {
  id       String               @id @default(cuid())
  type     StockTransactionType
  quantity Int
  notes    String?

  item   Item   @relation(fields: [itemId], references: [id])
  itemId String

  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  quotationId String?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([quotationId])
}

model Employee {
  id           String   @id @default(cuid())
  name         String
  mobile       String?
  email        String?
  role         String?
  baseSalary   Float    @default(0)
  advanceLimit Float    @default(0)
  joinDate     DateTime @default(now())
  active       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salaries         Salary[]
  salaryDeductions SalaryDeduction[]

  @@index([name])
}

model Salary {
  id         String @id @default(cuid())
  month      Int
  year       Int
  amount     Float
  notes      String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  deductions SalaryDeduction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([employeeId])
}

model SalaryDeduction {
  id          String   @id @default(cuid())
  amount      Float
  reason      String
  date        DateTime @default(now())
  notes       String?

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String

  salary      Salary?  @relation(fields: [salaryId], references: [id])
  salaryId    String?

  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([salaryId])
}
